# ====================================================
#  AI Meeting ActionFlow — backend-js Environment
# ====================================================
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to Git.
# ====================================================

# ── Groq AI + Whisper transcription ────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Google Sheets (two spreadsheets) ───────────────
GOOGLE_SHEET_ID=your_meetings_sheet_id_here
GOOGLE_USERS_SHEET_ID=your_users_sheet_id_here

# ── Google OAuth 2.0 (Login with Google) ───────────
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here

# ── Gmail SMTP (task notification emails) ──────────
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASSWORD=your_16char_app_password

# ── Server port ─────────────────────────────────────
PORT=8000
